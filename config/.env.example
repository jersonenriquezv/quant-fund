# OKX API
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
OKX_SANDBOX=true

# Etherscan API
ETHERSCAN_API_KEY=
# Coinglass API
COINGLASS_API_KEY=

# Claude API (para AI Service)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Master mute for the bot's routine alerts (shadow/session/market noise).
# false = only crash/error + live trade lifecycle reach Telegram; daily
# summary comes from scripts/daily_status.py instead. Edge alerts
# (signal_scanner) run separately and are unaffected.
BOT_TELEGRAM_ALERTS_ENABLED=true
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_fund
POSTGRES_USER=
POSTGRES_PASSWORD=
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Trading Config
TRADING_PAIRS=BTC/USDT,ETH/USDT
RISK_PER_TRADE=0.02
MAX_LEVERAGE=5
MAX_DAILY_DRAWDOWN=0.03
MAX_WEEKLY_DRAWDOWN=0.05
MAX_OPEN_POSITIONS=3
MAX_TRADES_PER_DAY=5
COOLDOWN_MINUTES=30
