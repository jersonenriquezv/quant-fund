      "targets": [
        {
          "rawSql": "SELECT clean_sample AS \"Clean\", COUNT(*) AS \"n\", ROUND(AVG(realized_r)::numeric,3) AS \"Expectancy R\", ROUND(SUM(pnl_usd)::numeric,2) AS \"Net $\" FROM bybit_trade_annotations WHERE journal_schema_version = 2 AND status = 'closed' AND closed_at >= NOW() - INTERVAL '180 days' GROUP BY clean_sample ORDER BY clean_sample NULLS LAST",
          "format": "table",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 100
          }
        }
      ]
    },
