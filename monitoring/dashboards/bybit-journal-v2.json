      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(realized_r) FILTER (WHERE clean_sample)::numeric,3) AS value FROM bybit_trade_annotations WHERE journal_schema_version = 2 AND status = 'closed' AND closed_at >= NOW() - INTERVAL '180 days'",
          "format": "table",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
