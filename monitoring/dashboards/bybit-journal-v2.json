      "targets": [
        {
          "rawSql": "SELECT COALESCE(ltf_trigger,'?') AS \"Trigger\", COUNT(*) AS \"n\", ROUND(AVG(mfe_r)::numeric,2) AS \"Avg MFE R\", ROUND(AVG(mae_r)::numeric,2) AS \"Avg MAE R\", ROUND(AVG(realized_r/NULLIF(mfe_r,0))::numeric,2) AS \"Exit Eff\" FROM bybit_trade_annotations WHERE journal_schema_version = 2 AND status = 'closed' AND closed_at >= NOW() - INTERVAL '180 days' AND clean_sample AND mfe_r > 0 GROUP BY ltf_trigger ORDER BY \"n\" DESC",
          "format": "table",
