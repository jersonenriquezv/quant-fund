      "targets": [
        {
          "rawSql": "SELECT setup_type, ROUND(SUM(pnl_usd)::numeric, 2) AS \"PnL $\", COUNT(*) AS \"Trades\" FROM trades WHERE status = 'closed' GROUP BY setup_type ORDER BY setup_type",
