      },
      "targets": [
        {
          "rawSql": "SELECT t.closed_at AS time, t.ai_confidence AS \"Confidence\", CASE WHEN t.pnl_usd > 0 THEN 1 ELSE 0 END AS \"Win (1) / Loss (0)\" FROM trades t WHERE t.status = 'closed' AND t.closed_at IS NOT NULL AND t.ai_confidence IS NOT NULL ORDER BY t.closed_at",
          "format": "time_series",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
