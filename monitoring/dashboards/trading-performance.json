      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT DATE_TRUNC('day', opened_at) AS time, COUNT(*) AS \"Trades\" FROM trades WHERE opened_at IS NOT NULL GROUP BY DATE_TRUNC('day', opened_at) ORDER BY time",
          "format": "time_series",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
