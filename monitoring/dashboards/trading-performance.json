    {
      "id": 9,
      "title": "Win Rate Rolling 7d",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT d.day AS time, ROUND(100.0 * SUM(CASE WHEN t.pnl_usd > 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS \"Win Rate %\" FROM generate_series(CURRENT_DATE - INTERVAL '30 days', CURRENT_DATE, '1 day') AS d(day) LEFT JOIN trades t ON DATE_TRUNC('day', t.closed_at) BETWEEN d.day - INTERVAL '6 days' AND d.day AND t.status = 'closed' GROUP BY d.day ORDER BY d.day",
          "format": "time_series",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
