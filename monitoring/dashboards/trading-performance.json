          "rawSql": "SELECT opened_at AS \"Opened\", pair AS \"Pair\", direction AS \"Dir\", setup_type AS \"Setup\", ROUND(entry_price::numeric, 2) AS \"Entry\", ROUND(actual_entry::numeric, 2) AS \"Fill\", ROUND(actual_exit::numeric, 2) AS \"Exit\", exit_reason AS \"Reason\", ROUND(pnl_usd::numeric, 2) AS \"PnL $\", ROUND((pnl_pct * 100)::numeric, 2) AS \"PnL %\", ROUND(ai_confidence::numeric, 2) AS \"AI Conf\" FROM trades WHERE status = 'closed' ORDER BY closed_at DESC LIMIT 50",
