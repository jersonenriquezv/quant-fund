      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT exit_reason AS metric, COUNT(*) AS value FROM trades WHERE status = 'closed' AND exit_reason IS NOT NULL GROUP BY exit_reason ORDER BY value DESC",
          "format": "table",
