{
  "uid": "trading-performance",
  "title": "Trading Performance",
  "tags": [
    "trading"
  ],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Equity Curve (Cumulative PnL)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT closed_at AS time, SUM(pnl_usd) OVER (ORDER BY closed_at) AS \"Cumulative PnL ($)\" FROM trades WHERE status = 'closed' AND closed_at IS NOT NULL ORDER BY closed_at",
          "format": "time_series",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Summary Stats",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Total Trades\", SUM(CASE WHEN pnl_usd > 0 THEN 1 ELSE 0 END) AS \"Wins\", ROUND(100.0 * SUM(CASE WHEN pnl_usd > 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS \"Win Rate %\", ROUND(SUM(pnl_usd)::numeric, 2) AS \"Total PnL $\" FROM trades WHERE status = 'closed'",
          "format": "table",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "Win Rate by Setup Type",
      "type": "bargauge",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT setup_type AS metric, ROUND(100.0 * SUM(CASE WHEN pnl_usd > 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS value FROM trades WHERE status = 'closed' GROUP BY setup_type ORDER BY setup_type",
          "format": "table",
          "refId": "A",
          "editorMode": "code",
          "rawQuery": true,
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
