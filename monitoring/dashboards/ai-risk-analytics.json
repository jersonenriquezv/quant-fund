{
  "uid": "ai-risk-analytics",
  "title": "AI & Risk Analytics",
  "tags": ["ai", "risk"],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "AI Approval Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT DATE_TRUNC('day', created_at) AS time, ROUND(100.0 * SUM(CASE WHEN approved = true THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS \"Approval Rate %\" FROM ai_decisions WHERE $__timeFilter(created_at) GROUP BY DATE_TRUNC('day', created_at) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "AI Stats (All Time)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Total Evaluations\", SUM(CASE WHEN approved = true THEN 1 ELSE 0 END) AS \"Approved\", ROUND(100.0 * SUM(CASE WHEN approved = true THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS \"Approval Rate %\", ROUND(AVG(CASE WHEN approved = true THEN confidence ELSE NULL END)::numeric, 2) AS \"Avg Confidence (Approved)\" FROM ai_decisions",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Confidence Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT confidence AS \"Confidence\" FROM ai_decisions WHERE confidence > 0",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "bucketSize": 0.05,
        "fillOpacity": 80
      }
    },
    {
      "id": 4,
      "title": "AI Approval Rate by Setup Type",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT setup_type AS metric, ROUND(100.0 * SUM(CASE WHEN approved = true THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS value FROM ai_decisions WHERE setup_type IS NOT NULL GROUP BY setup_type ORDER BY setup_type",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Risk Events Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT DATE_TRUNC('day', created_at) AS time, event_type AS metric, COUNT(*) AS value FROM risk_events WHERE $__timeFilter(created_at) GROUP BY DATE_TRUNC('day', created_at), event_type ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 50
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Guardrail Trigger Frequency",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT event_type AS metric, COUNT(*) AS value FROM risk_events GROUP BY event_type ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent AI Decisions",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT created_at AS \"Time\", pair AS \"Pair\", direction AS \"Dir\", setup_type AS \"Setup\", CASE WHEN approved THEN 'YES' ELSE 'NO' END AS \"Approved\", ROUND(confidence::numeric, 2) AS \"Confidence\", LEFT(reasoning, 120) AS \"Reasoning\" FROM ai_decisions ORDER BY created_at DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
