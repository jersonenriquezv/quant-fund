{
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(~/quant-fund/**)",
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(pytest*)",
      "Bash(docker*)",
      "Bash(cat*)",
      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(mkdir*)",
      "Bash(source*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jer/quant-fund/scripts/check-critical-commit.sh"
          }
        ]
      }
    ]
  }
}
